# ZALO_OA_REFRESH_TOKEN=
# ZALO_OA_APP_ID=
# ZALO_OA_APP_SECRET=
# ZNS_TEMPLATE_ID_BOOKING_CONFIRM=
# OWNER_ZALO_PHONE=
# CRON_SECRET=
