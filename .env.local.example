# =========================================================================
# Phase 07 v1 — Supabase backend env
# Copy to .env.local and fill in real values. NEVER commit real keys.
# =========================================================================

# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...           # SERVER ONLY — never expose to browser

# Site
NEXT_PUBLIC_SITE_URL=https://nguyenvantai.com

# IP hash salt (32+ random chars — generate per environment, never reuse across envs)
IP_HASH_SALT=replace-with-32-char-random-string

# Server timezone hint (Vercel/Node)
TZ=Asia/Ho_Chi_Minh

# =========================================================================
# Admin dashboard (admin.nguyenvantai.com)
# - ADMIN_PASSWORD: mật khẩu plain text, chỉ owner biết. Tối thiểu 12 ký tự.
# - ADMIN_SESSION_SECRET: 32+ ký tự random, dùng ký session token (HMAC-SHA256).
# =========================================================================
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_SESSION_SECRET=replace-with-32-char-random-string

# =========================================================================
# Optional webhook v1 — Discord / Slack notify owner sau khi insert.
# Empty = bỏ qua webhook, owner check Supabase Studio.
# Fire-and-forget từ /api/book, không retry, không log. Nếu fail thì miss.
# =========================================================================
WEBHOOK_URL=

# =========================================================================
# Meta Pixel + Conversions API
# - NEXT_PUBLIC_META_PIXEL_ID is public and used by browser Pixel.
# - META_CAPI_ACCESS_TOKEN is server-only. NEVER expose it to browser or git.
# - META_CAPI_API_VERSION can be bumped when Meta deprecates older versions.
# =========================================================================
NEXT_PUBLIC_META_PIXEL_ID=1658487875083016
META_CAPI_ACCESS_TOKEN=
META_CAPI_API_VERSION=v24.0
META_CAPI_TEST_EVENT_CODE=

# =========================================================================
# MCP server (/api/mcp) — Model Context Protocol endpoint for chatbots.
# - MCP_API_KEY: 32+ ký tự random. Mọi request bắt buộc gửi header
#   `Authorization: Bearer <key>`. Empty/missing/<16 chars → 503.
# - Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =========================================================================
MCP_API_KEY=

# =========================================================================
# v1.5 (deferred — Zalo OA / ZNS / outbox queue / cron workers).
# =========================================================================
